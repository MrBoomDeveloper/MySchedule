---
import Button from "@/components/Button.astro";
import database from "@/database";
import { useI18n } from "@/i18n/useI18n.astro";
import { getUsernameByToken } from "@/utils";

export const prerender = false;

const id = Astro.params.id;
const user = await getUsernameByToken(Astro.cookies.get("token")!!.value);
const isLoggedIn = user != null;

const schedule = database.prepare('SELECT * FROM schedules WHERE id = ?').get(id);
const currentDayOfWeek = new Date().getDay() - 1;
const canEdit = schedule.owner == user;

if(schedule == null || (schedule.isPublic == "false" && !canEdit)) {
    return Astro.redirect("/404", 404);
}

const tasks = database.prepare('SELECT * FROM tasks WHERE schedule = ?').all(id);

const i18n = useI18n(Astro.preferredLocale);

const dayOfWeekNames = [
    i18n.monday,
    i18n.tuesday,
    i18n.wednesday,
    i18n.thursday,
    i18n.friday,
    i18n.friday,
    i18n.sunday
];

function getFormattedWeekRange() {
    const now = new Date();
    
    // 1. Get the current day (0 for Sun, 1 for Mon, ..., 6 for Sat)
    const dayOfWeek = now.getDay(); 
  
    // 2. Adjust so Monday is the first day (offset calculation)
    // If today is Sunday (0), we go back 6 days. Otherwise, go back (day - 1)
    const diffToMonday = dayOfWeek === 0 ? -6 : 1 - dayOfWeek;

    const monday = new Date(now);
    monday.setDate(now.getDate() + diffToMonday);
  
    const sunday = new Date(monday);
    sunday.setDate(monday.getDate() + 6);

    // 3. Formatting Helpers
    const formatMonth = (date: Date) => {
        switch(date.getMonth()) {
            case 1: return i18n.january;
            case 2: return i18n.february;
            case 3: return i18n.march;
            case 4: return i18n.april;
            case 5: return i18n.may;
            case 6: return i18n.june;
            case 7: return i18n.july;
            case 8: return i18n.august;
            case 9: return i18n.september;
            case 10: return i18n.october;
            case 11: return i18n.november;
            case 12: return i18n.december;
        }
    }

    const formatYear = (date: Date) => date.getFullYear();
  
    const mDay = monday.getDate();
    const mMonth = formatMonth(monday);
    const mYear = formatYear(monday);
  
    const sDay = sunday.getDate();
    const sMonth = formatMonth(sunday);
    const sYear = formatYear(sunday);

    // 4. Logic for different scenarios
    if(mYear !== sYear) {
        // Different Years: "December 29, 2025 - January 4, 2026"
        return `${mMonth} ${mDay}, ${mYear} - ${sMonth} ${sDay}, ${sYear}`;
    } else if (mMonth !== sMonth) {
        // Different Months: "January 31 - February 6"
        return `${mMonth} ${mDay} - ${sMonth} ${sDay}`;
    } else {
        // Same Month: "January 1-7"
        return `${mMonth} ${mDay}-${sDay}`;
    }
}
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="color-scheme" content="light dark" />
		<meta name="darkreader-lock" />
		<title>MySchedule - {id}</title>
    </head>

    <body>
        <header>
            {canEdit && <a href="/dashboard">
                <img class="back" src="/icons/back_bold.svg" />
            </a>}

            <span class="title">{schedule.name}</span>

            <span class="spacer"></span>

            <div class="search">
                <img src="/icons/search.svg" />
                <input placeholder={i18n.search_calendar} />
            </div>

            <span class="spacer"></span>

            {!isLoggedIn && <a href="/auth/signin">
                <Button text="Sign in" />
            </a>}

            {schedule.public == "true" && <Button icon="/icons/link.svg" text={i18n.share} id="share" />}

            {canEdit && <a href={`/schedule/${schedule.id}/manage`}>
                <Button icon="/icons/settings.svg" text={i18n.manage} />
            </a>}
        </header>

        <div class="actions">
            <Button squircle icon="/icons/back.svg" />
            <span class="week">{getFormattedWeekRange()}</span>

            <div style="scale: -1">
                <Button squircle icon="/icons/back.svg" />
            </div>

            <span class="spacer"></span>

            <a href={`/schedule/${schedule.id}/month`}>
                <Button squircle icon="/icons/calendar_month_filled.svg" />
            </a>
        </div>

        <div class="days">
            {[0, 1, 2, 3, 4, 5, 6].map(index => (
                <div class="day" class:list={{active: index == currentDayOfWeek}}>
                    <div class="day-header">
                        <span class="day-name">{dayOfWeekNames[index]}</span>
                        {canEdit && <Button transparent icon="/icons/add.svg" />}
                    </div>

                    {[0, 1, 2, 3, 4, 5, 6].map(index => (
                        <div class="task">
                            <span class="task-time">8:00-9:35</span>
                            <span class="task-name">Таска  {index}</span>
                            <span class="task-duration">1 час</span>
                        </div>
                    ))}
                </div>
            ))}
        </div>
    </body>
</html>

<style lang="scss">
    @use "@/styles/reset";
    @use "@/styles/colors";
    @use "@/styles/vars";

    .spacer {
        flex-grow: 1;
    }

    header {
        padding: 1rem;
        display: flex;
        align-items: center;
        gap: .8rem;

        .back {
            height: 1.8em;
            aspect-ratio: 1;
        }

        .title {
            font-weight: 900;
		    font-size: 2em;
		    font-variation-settings: "wdth" 125;
        }
    }

    .search {
        display: flex;
        gap: .6rem;
        align-items: center;
        background-color: rgb(21, 21, 21);
        border-radius: 2rem;
        padding-block: .4rem;
        padding-left: .8rem;
        padding-right: 1.4rem;
        width: 100%;
        max-width: 25rem;

        img {
            height: 1.4em;
            aspect-ratio: 1;
            filter: brightness(0) saturate(100%) invert(81%) sepia(0%) saturate(367%) hue-rotate(208deg) brightness(93%) contrast(86%);
        }

        input {
            flex-grow: 1;
            border: none;
            background-color: transparent;
            font-size: 1em;

            &:focus {
                outline: none;
            }
        }
    }

    .actions {
        padding: 1rem;
        display: flex;
        gap: 1.75rem;

        .week {
            font-weight: 900;
		    font-size: 1.75em;
		    font-variation-settings: "wdth" 125;
            font-style: italic;
        }
    }

    .days {
        overflow: scroll;
        padding: 1rem;
        display: flex;
        gap: 1rem;
    }

    .task {
        display: flex;
        flex-direction: column;
        width: 100%;
        background-color: white;
        color: black;
        padding-block: .6rem;
        padding-inline: 1rem;

        .task-time {
            font-size: .95em;
        }

        .task-name {
            font-weight: 600;
            font-size: 1.1em;
        }

        .task-duration {
            margin-top: .1rem;
            font-size: .9em;
        }

        &:last-child {
            border-radius: 0 0 .75rem .75rem;
        }
    }

    .day {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        width: 0;
        min-width: 10rem;
        gap: .25rem;

        &:not(.active) {
            opacity: .8;

            .task {
                background-color: transparent;
                color: white;
                border: .1em white solid;
            }
        }

        .day-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .day-name {
            font-weight: 600;
		    font-size: 1.2em;
            margin-bottom: .6rem;
        }
    }

    .day-header + .task {
        border-radius: .75rem .75rem 0 0;
    }

    @media (max-width: 1100px) {
        .search {
            display: none;
        }
    }
</style>

<script>
    document.getElementById("share")?.addEventListener("click", () => {
        navigator.clipboard.writeText(window.location.href);
        alert("Copied to clipboard!");
    });
</script>